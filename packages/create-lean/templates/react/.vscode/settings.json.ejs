{
  "files.autoSave": "onFocusChange",
  "editor.fontSize": 14,
  "editor.tabSize": 2,
  "editor.formatOnSave": true,
  <% if (needsPrettier) { %>"editor.defaultFormatter": "esbenp.prettier-vscode",<% } %>
  <% if (needsEslint) { %>"editor.codeActionsOnSave": {
    "source.fixAll.eslint": "always",
  }<% } %>
}
