{
  "parser": "@typescript-eslint/parser",
  "parserOptions": {
    "ecmaVersion": 7,
    "sourceType": "module",
    "ecmaFeatures": {
      "jsx": true
    }
  },
  "env": {
    "es6": true,
    "node": true,
    "browser": true
  },
  "globals": {
    "document": true,
    "navigator": true,
    "window": true
  },
  "ignorePatterns": [
    "dist"
  ],
  "extends": [
    "airbnb",
    "plugin:react/jsx-runtime",
    "plugin:react-hooks/recommended",
    <% if (needsPrettier) { %>"plugin:prettier/recommended"<% } %>
  ],
  "plugins": [
    "react",
    "jsx-a11y",
    "import"
  ],
  "rules": {
    <% if (needsPrettier) { %>"prettier/prettier": [
      "error",
      {
        "singleQuote": true,
        "semi": false
      }
    ],<% } %>
    "import/prefer-default-export": "off",
    "import/no-unresolved": "off",
    "consistent-return": "off",
    "import/extensions": "off"
  }
}
